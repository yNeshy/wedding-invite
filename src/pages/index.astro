---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mayssa & Aziz – Wedding Invitation</title>
    <link rel="icon" type="image/png" href="/assets/rings.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-cream text-soil font-display">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center">
      <img
        src="/assets/background image 1.jpg"
        alt="Garden wedding scene"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 mx-4 max-w-md w-full bg-cream/95 backdrop-blur-sm rounded-2xl px-6 py-10 text-center shadow-xl">
        <p class="text-base md:text-lg tracking-widest uppercase mb-6">Together with their families</p>
        <p class="text-lg md:text-xl mb-6">Family Yacoubi &amp; Family Nechi</p>
        <p class="text-base md:text-lg italic mb-4">invite you to the wedding of</p>
        <h1 class="text-5xl md:text-6xl font-bold mb-8">Mayssa &amp; Aziz</h1>
        <div class="w-16 h-px bg-accent mx-auto mb-8"></div>
        <p class="text-xl md:text-2xl font-semibold">September 18, 2026</p>
        <p class="text-lg md:text-xl mt-2">20h00 – 00h00</p>
        <p class="text-lg md:text-xl mt-2">Dar Bouraoui, La Marsa</p>
      </div>
    </section>

    <!-- Location Section -->
    <section class="bg-cream py-20 px-6 text-center">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Dar Bouraoui</h2>
        <p class="text-xl mb-10">La Marsa, Tunisia</p>
        <div class="w-16 h-px bg-accent mx-auto mb-10"></div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://maps.app.goo.gl/JPMzeR5uZHT3Q4VD9"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-3 bg-accent text-cream rounded-full font-semibold tracking-wide hover:opacity-90 transition-opacity"
          >
            Open in Google Maps
          </a>
          <a
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Wedding+of+Mayssa+%26+Aziz&dates=20260918T170000/20260919T010000&location=Dar+Bouraoui%2C+La+Marsa%2C+Tunisia&details=Wedding+celebration+of+Mayssa+%26+Aziz+at+Dar+Bouraoui%2C+La+Marsa."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-3 border-2 border-accent text-accent rounded-full font-semibold tracking-wide hover:bg-accent hover:text-cream transition-colors"
          >
            Add to Google Calendar
          </a>
        </div>
      </div>
    </section>

    <!-- Blessed Verse Section -->
    <section class="bg-cream py-20 px-6 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="w-16 h-px bg-accent mx-auto mb-12"></div>
        <p dir="rtl" lang="ar" class="text-2xl md:text-3xl leading-relaxed mb-4">
          وَمِنْ آيَاتِهِ أَنْ خَلَقَ لَكُم مِّنْ أَنفُسِكُمْ أَزْوَاجًا لِّتَسْكُنُوا إِلَيْهَا وَجَعَلَ بَيْنَكُم مَّوَدَّةً وَرَحْمَةً ۚ إِنَّ فِي ذَٰلِكَ لَآيَاتٍ لِّقَوْمٍ يَتَفَكَّرُونَ
        </p>
        <p dir="rtl" lang="ar" class="text-base text-soil/70 mb-10">سورة الرّوم - ٢١</p>
        <p class="text-lg md:text-xl italic leading-relaxed mb-4">
          "And of His signs is this: He created for you helpmeets from yourselves that you might find rest in them, and He ordained between you love and mercy."
        </p>
        <p class="text-base text-soil/70">Surah Ar-Rum - 21</p>
        <div class="w-16 h-px bg-accent mx-auto mt-12"></div>
      </div>
    </section>
  </body>
</html>
